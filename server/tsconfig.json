{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020"],
        "module": "nodenext",
        "moduleResolution":"nodenext",
        "types": ["node"],
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "./**/*.ts",
        "./**/*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}